{{> head}}
<body>
    {{> header}}

    <main class="container page-blog">
        <div class="page-header reveal">
            <div class="breadcrumb">
                <a href="/" data-i18n="nav_home">Início</a> 
                <i class="fa-solid fa-chevron-right"></i> 
                <span class="active" data-i18n="nav_blog">{{blogPage.breadcrumb}}</span>
            </div>
            <h1 class="page-title" data-i18n="page_blog_title">{{blogPage.title}}</h1>
            <p class="page-subtitle" data-i18n="page_blog_sub">{{blogPage.subtitle}}</p>
        </div>

        <div class="blog-list" id="blog-container">
            <div class="blog-loader" style="text-align: center; padding: 50px; color: var(--text-muted);">
                <i class="fa-solid fa-spinner fa-spin fa-2x"></i>
                <p style="margin-top: 15px;">{{blogPage.loadingText}}</p>
            </div>
        </div>
    </main>

    {{> footer}}
    {{> scripts}}
</body>
</html>