<header id="main-header">
    <div class="container nav-container">
        <a href="/" class="logo">
            <span style="color: var(--text-muted);">{{{brand.symbol}}}</span>{{brand.cursor}}
        </a>

        <nav class="nav-links">
            {{#navLinks}}
            <a href="{{href}}"{{#isActive}} class="active"{{/isActive}} data-i18n="{{i18nKey}}">{{label}}</a>
            {{/navLinks}}
        </nav>

        <div class="nav-actions">
            <button class="btn-action btn-icon" id="theme-toggle" title="Alternar Tema">
                <i class="fa-solid fa-moon"></i>
            </button>

            <div class="dropdown">
                <button class="btn-action btn-lang" id="lang-btn">
                    <span>{{language.currentCode}}</span> {{language.currentLabel}}
                    <i class="fa-solid fa-chevron-down"></i>
                </button>
                <div class="dropdown-menu" id="lang-menu">
                    <a href="#" class="dropdown-item active"><i class="fa-solid fa-flag"></i> Português</a>
                    <a href="#" class="dropdown-item"><i class="fa-solid fa-earth-americas"></i> English</a>
                </div>
            </div>

            {{#socialLinks}}
            <a href="{{url}}" class="btn-action btn-icon" title="{{label}}">
                <i class="{{icon}}"></i>
            </a>
            {{/socialLinks}}
        </div>

        <button class="menu-btn" id="mobile-menu-btn">
            <i class="fa-solid fa-bars"></i>
        </button>
    </div>
</header>